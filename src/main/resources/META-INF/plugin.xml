<idea-plugin>
    <id>com.hijson.flutter.plugin</id>
    <name>Flutter Hi Json</name>
    <vendor url="https://github.com/AndyAls/flutter_hi_json">HiJson</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Flutter Hi Json" displayType="BALLOON"/>
        <projectService serviceImplementation="com.hijson.flutter.plugin.config.PluginSettings"/>
        <projectConfigurable
            parentId="tools"
            instance="com.hijson.flutter.plugin.config.PluginSettingsConfigurable"
            id="com.hijson.flutter.plugin.config.PluginSettingsConfigurable"
            displayName="Flutter Hi Json"
            nonDefaultProject="false"/>
    </extensions>

    <actions>
        <action
            id="FlutterHiJson.NewAction"
            class="com.hijson.flutter.plugin.action.FlutterHiJsonAction"
            text="Flutter Hi Json"
            description="Generate Dart entity class from JSON"
            icon="/icons/hijson.svg">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="after" relative-to-action="NewGroup"/>
        </action>
    </actions>
</idea-plugin>
